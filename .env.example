# --- Butterbase backend (optional) ---
# Without these, APEX runs fully on-device (localStorage). With them, users
# get real accounts, profile sync, and a shared live feed.
# Setup:
#   npx @butterbase/cli login                            # paste your Butterbase API key
#   npx @butterbase/cli apps create apex                 # note the app_… id
#   npx @butterbase/cli schema apply butterbase/schema.json
VITE_BUTTERBASE_APP_ID=
# VITE_BUTTERBASE_API_URL=https://api.butterbase.ai
# VITE_BUTTERBASE_ANON_KEY=

# --- Claude AI plans (optional, server-side) ---
# Either set this and `npm run server`, or install Claude Code
# (npm i -g @anthropic-ai/claude-code + /login) and `npm run server` with no key.
# ANTHROPIC_API_KEY=
